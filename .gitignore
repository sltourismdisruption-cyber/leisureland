# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# but keep the example so devs know which keys are needed
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python cache (from bundled .claude skills)
__pycache__/
*.pyc

# Local Claude settings (personal, not shared)
.claude/settings.local.json

# macOS
.DS_Store

# graphify generated knowledge graph (rebuild with: graphify update .)
/graphify-out/

# Photo working files — never commit raw originals or working copies
RawImages/
staging/
staging-optimized/
staging copy/
build_review.py
review.html

# TinaCMS generated files (rebuilt by `tinacms build`)
.tina/__generated__/
tina/__generated__/
